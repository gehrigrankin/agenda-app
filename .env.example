# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. NEVER commit secrets.
# `.env.local` is gitignored.
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) ----------------------------------------------
# Use the *pooled* connection string from the Neon dashboard for the app, and
# the same (or direct) string for drizzle-kit migrations.
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://user:password@your-neon-host.neon.tech/agenda?sslmode=require"

# --- Auth (Clerk) ----------------------------------------------------------
# From the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Where Clerk should send users for auth. These match the routes scaffolded
# under src/app/(auth). Override only if you change those routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/app"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/app"

# --- File storage ----------------------------------------------------------
# The storage layer (src/lib/storage) supports three drivers:
#   local — dev stub, writes to public/uploads (ephemeral on serverless hosts)
#   db    — bytes in Postgres, served via /api/uploads (default when
#           DATABASE_URL is set and STORAGE_DRIVER is unset; personal-scale)
#   s3    — production path: set STORAGE_DRIVER=s3 and fill the S3_* vars.
STORAGE_DRIVER="local"
# Required for STORAGE_DRIVER=s3. Returned image URLs point straight at the
# bucket, so the bucket/prefix must be publicly readable (or front it with a
# CDN via S3_PUBLIC_BASE_URL below).
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# Optional: base URL for returned object URLs, e.g. a CloudFront/R2 public
# domain ("https://cdn.example.com" — the object key is appended).
# S3_PUBLIC_BASE_URL=""
# Optional: custom endpoint for S3-compatible stores (R2, MinIO, ...);
# switches the client to path-style addressing.
# S3_ENDPOINT=""

# --- Maintenance -------------------------------------------------------------
# Shared secret for the on-demand migration route (/api/db/migrate). The route
# is disabled (404) unless this is set; requests must send it via the
# `x-migrate-key` header or `?key=` param. Generate with: openssl rand -hex 32
# MIGRATE_SECRET=""

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
