# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. NEVER commit secrets.
# `.env.local` is gitignored.
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) ----------------------------------------------
# Use the *pooled* connection string from the Neon dashboard for the app, and
# the same (or direct) string for drizzle-kit migrations.
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://user:password@your-neon-host.neon.tech/agenda?sslmode=require"

# --- Auth (Clerk) ----------------------------------------------------------
# From the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Where Clerk should send users for auth. These match the routes scaffolded
# under src/app/(auth). Override only if you change those routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/app"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/app"

# --- File storage ----------------------------------------------------------
# The storage layer (src/lib/storage) ships with a local stub adapter.
# Set STORAGE_DRIVER=s3 and fill the S3 vars once an S3 adapter is added.
STORAGE_DRIVER="local"
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# --- Maintenance -------------------------------------------------------------
# Shared secret for the on-demand migration route (/api/db/migrate). The route
# is disabled (404) unless this is set; requests must send it via the
# `x-migrate-key` header or `?key=` param. Generate with: openssl rand -hex 32
# MIGRATE_SECRET=""

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
